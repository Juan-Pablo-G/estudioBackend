PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME
PGSSL=false

# JWT Secret (genera uno seguro)
JWT_SECRET=change_me_local_dev_secret

# Cloudinary (obten de https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=tu_cloud_name_aqui
CLOUDINARY_API_KEY=tu_api_key_aqui
CLOUDINARY_API_SECRET=tu_api_secret_aqui

# MailerSend (obten de https://www.mailersend.com/)
MAILERSEND_ENABLED=true
MAILERSEND_API_KEY=tu_mailersend_api_key_aqui
MAILERSEND_FROM_EMAIL=no-reply@tu-dominio.com
MAILERSEND_FROM_NAME=WebPinterest
MAILERSEND_REPLY_TO_EMAIL=soporte@tu-dominio.com
MAILERSEND_REPLY_TO_NAME=Soporte WebPinterest
